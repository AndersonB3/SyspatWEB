# ============================================================
# SysWebPat Backend — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA commite o arquivo .env com valores reais!
# ============================================================

# Supabase — obtenha em: Supabase Dashboard > Settings > API
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=seu_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=seu_service_role_key_aqui

# PostgreSQL direto — Supabase > Settings > Database > Connection string
# Usado apenas pelos scripts de migration
SUPABASE_DB_PASSWORD=sua_senha_postgres_aqui

# JWT — gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=gere_um_segredo_com_minimo_32_caracteres_aqui
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# App
APP_ENV=development
APP_PORT=8080
CORS_ORIGINS=http://localhost:3000
